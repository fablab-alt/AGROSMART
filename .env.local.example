# ============================================================
# .env.local.example — Config Docker LOCAL (test comme en prod)
# ============================================================
# 1. Copie ce fichier : cp .env.local.example .env
# 2. Génère les secrets avec les commandes indiquées
# 3. Lance : docker compose up --build
# ============================================================

# Ports exposés sur ta machine
BACKEND_PORT=3600
FRONTEND_PORT=3603

# ── Base de données (conteneur Docker interne) ───────────────
DB_NAME=agrismart_ci
DB_USER=agrismart
# Choisis un mot de passe pour le conteneur MySQL local
DB_PASSWORD=DevPassword123_change_me
DB_ROOT_PASSWORD=RootPass123_change_me
DB_PORT=3306
DB_SSL=false
DB_POOL_SIZE=5
DB_POOL_TIMEOUT=20
DB_CONNECT_TIMEOUT=10
# Utilisé par Prisma à l'intérieur du conteneur backend (host = nom du service docker)
DATABASE_URL=mysql://agrismart:DevPassword123_change_me@db:3306/agrismart_ci?connection_limit=5&pool_timeout=20&connect_timeout=10

# ── Secrets JWT & cookies ────────────────────────────────────
# Génère avec : openssl rand -base64 64
JWT_SECRET=REMPLACE_MOI_openssl_rand_base64_64
JWT_REFRESH_SECRET=REMPLACE_MOI_DIFFERENT_openssl_rand_base64_64
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
# Génère avec : openssl rand -base64 32
COOKIE_SECRET=REMPLACE_MOI_openssl_rand_base64_32
# Génère avec : openssl rand -hex 32
AI_INTERNAL_TOKEN=REMPLACE_MOI_openssl_rand_hex_32

# ── CORS (frontend → backend) ────────────────────────────────
CORS_ORIGIN=http://localhost:3603
ALLOWED_ORIGINS=http://localhost:3603
ALLOW_LOCALHOST_CORS=true

# ── Frontend ─────────────────────────────────────────────────
# URL appelée depuis le navigateur (pas depuis Docker)
NEXT_PUBLIC_API_URL=http://localhost:3600/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3600
NEXTAUTH_URL=http://localhost:3603
NEXTAUTH_SECRET=

# ── Redis (interne Docker, pas besoin de changer) ────────────
REDIS_URL=redis://redis:6379

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE=./logs/app.log
TZ=Africa/Abidjan
APP_VERSION=1.0.0
API_VERSION=v1

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# ── Services optionnels (laisser vide = désactivé) ───────────

# Météo — gratuit sur openweathermap.org
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_API_KEY=
OPENWEATHER_API_KEY=

# SMS/OTP — compte Twilio (twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Email — ex Gmail : smtp.gmail.com port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=AgroSmart <noreply@agrosmart.ci>

# IoT MQTT (laisser vide si pas de capteurs)
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=agrosmart/+/up
IOT_RATE_LIMIT=60
IOT_GATEWAY_SECRET=
LORA_NETWORK_KEY=

# IA & IoT services (si tu les lances séparément)
AI_SERVICE_URL=
IOT_SERVICE_URL=

# Domaines prod (ignorés en local)
DOMAIN=localhost
API_DOMAIN=localhost
