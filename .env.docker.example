# ============================================================
# AgroSmart CI — Template d'environnement pour Docker local
# Copier ce fichier en .env.docker et remplir les valeurs.
# Usage : docker compose -f docker-compose.dev.yml --env-file .env.docker up
# ============================================================

# ---- Domaines (non utilisé localement, mais requis par le Dockerfile) ----
DOMAIN=localhost
API_DOMAIN=localhost

# ---- Ports ----
BACKEND_PORT=3600
FRONTEND_PORT=3603

# ---- App ----
NODE_ENV=production
API_VERSION=v1
APP_VERSION=1.0.0
TZ=Africa/Abidjan

# ---- MySQL local (service 'mysql' dans docker-compose.dev.yml) ----
# ⚠️  Changer ces mots de passe avant tout déploiement réel
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=agrosmart
MYSQL_USER=agrosmart
MYSQL_PASSWORD=changeme_user_password

DB_HOST=mysql
DB_PORT=3306
DB_NAME=agrosmart
DB_USER=agrosmart
DB_PASSWORD=changeme_user_password
DB_SSL=false
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=20
DB_CONNECT_TIMEOUT=10
DATABASE_URL=mysql://agrosmart:changeme_user_password@mysql:3306/agrosmart

# ---- JWT (générer 64+ caractères aléatoires en production) ----
# Exemple : openssl rand -hex 64
JWT_SECRET=replace_with_64_chars_random_secret_for_jwt_signing_in_production_xxxxxxxx
JWT_REFRESH_SECRET=replace_with_64_chars_random_secret_for_refresh_tokens_in_production_xxx
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3603,http://127.0.0.1:3603
CORS_ORIGIN=http://localhost:3603,http://127.0.0.1:3603
ALLOW_LOCALHOST_CORS=true

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE=./logs/app.log
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=2000

# ---- Frontend — URL API accessible depuis le navigateur (host machine) ----
NEXT_PUBLIC_API_URL=http://localhost:3600/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3600

# ---- NextAuth (optionnel) ----
NEXTAUTH_URL=http://localhost:3603
NEXTAUTH_SECRET=replace_with_random_secret

# ---- Seed au premier démarrage ----
RUN_SEED=true

# ---- Intégrations optionnelles (laisser vide en local) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=AgroSmart <noreply@agrosmart.ci>

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

WEATHER_API_URL=https://meteo.voisilab.online/api
WEATHER_API_KEY=
OPENWEATHER_API_KEY=

AI_SERVICE_URL=
IOT_SERVICE_URL=
IOT_GATEWAY_SECRET=
LORA_NETWORK_KEY=
