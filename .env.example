# ================================
# AgroSmart Docker VPS Environment
# Frontend + Backend only
# ================================

# Domains routed by Traefik
DOMAIN=agrosmart.voisilab.online
API_DOMAIN=api.agrosmart.voisilab.online

# Container ports
BACKEND_PORT=3600
FRONTEND_PORT=3603

# ================================
# Backend runtime
# ================================
NODE_ENV=production
API_VERSION=v1
APP_VERSION=1.0.0
TZ=Africa/Abidjan

# MySQL on VPS host machine
# Use host.docker.internal with host-gateway mapping in docker-compose
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=agrismart_ci
DB_USER=agrismart_user
DB_PASSWORD=change_this_db_password
DB_SSL=true
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=20
DB_CONNECT_TIMEOUT=10

# URL used by Prisma
DATABASE_URL=mysql://agrismart_user:change_this_db_password@host.docker.internal:3306/agrismart_ci?connection_limit=10&pool_timeout=20&connect_timeout=10

# JWT & cookies — OBLIGATOIRE en production
# Générer avec : openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_base64_64_different
COOKIE_SECRET=change_me_generate_with_openssl_rand_base64_32
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Authentification inter-services IA (X-Internal-Token)
# Générer avec : openssl rand -hex 32
AI_INTERNAL_TOKEN=change_me_generate_with_openssl_rand_hex_32

# CORS (frontend and API public origins)
ALLOWED_ORIGINS=https://agrosmart.voisilab.online,https://api.agrosmart.voisilab.online
CORS_ORIGIN=https://agrosmart.voisilab.online,https://api.agrosmart.voisilab.online

# Logging / limits
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE=./logs/app.log
RATE_LIMIT_WINDOW_MS=60000
# Réduire à 200-500 en production pour protéger contre le DoS
RATE_LIMIT_MAX_REQUESTS=200

# MQTT IoT (broker privé obligatoire en production)
MQTT_BROKER_URL=mqtt://your-private-broker:1883
MQTT_USERNAME=change_me
MQTT_PASSWORD=change_me
MQTT_TOPIC=agrosmart/+/up
IOT_RATE_LIMIT=60

# Optional: enable the worker service with `docker compose --profile worker up -d`
# COMPOSE_PROFILES=worker

# Frontend build/runtime vars
NEXT_PUBLIC_API_URL=https://api.agrosmart.voisilab.online/api/v1
NEXT_PUBLIC_SOCKET_URL=https://api.agrosmart.voisilab.online

# If NextAuth is enabled later
NEXTAUTH_URL=https://agrosmart.voisilab.online
NEXTAUTH_SECRET=

# Optional integrations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=AgroSmart <noreply@agrosmart.ci>

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
WEATHER_API_KEY=
OPENWEATHER_API_KEY=

AI_SERVICE_URL=
IOT_SERVICE_URL=
IOT_GATEWAY_SECRET=
LORA_NETWORK_KEY=

# Redis (optionnel — améliore rate-limit et brute-force en production cluster)
# Ex: redis://localhost:6379 ou redis://:password@redis-host:6379
REDIS_URL=
